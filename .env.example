# Supabase — replace with your project credentials
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.supabase.co:5432/postgres
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_KEY=your-anon-key

# Google Places API (for autocomplete + place details)
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Mapbox (for map in dashboard/share views)
VITE_MAPBOX_TOKEN=your-mapbox-token
